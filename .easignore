# Explicitly ignore root-level directories for Next.js web app
/node_modules/
/.next/
/app/
/components/
/public/
/supabase/
/tests/
/i18n/
/lib/
/hooks/
/messages/
/data/
/.codesight/
/.vscode/
/.pytest_cache/
/.verdent/

# Explicitly ignore root-level files
/*.docx
/*.png
/*.html
/*.txt
/*.log
/*.json
/package-lock.json
/package.json
/eslint.config.mjs
/postcss.config.mjs
/tsconfig.json
/next.config.ts
/next-env.d.ts
/next-sitemap.config.js
/proxy.ts
